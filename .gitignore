# ============================================================
# ReconAI — Git Ignore Rules
# ============================================================

# --- CRITICAL: Never commit your real API keys ---
.env
.env.example

# --- Python cache files ---
__pycache__/
*.py[cod]
*$py.class
*.pyc

# --- Virtual environment folder ---
venv/
env/
.venv/

# --- Generated reports (optional: remove if you want to track them) ---
reports/*.md
reports/*.pdf
reports/*.docx

# --- OS junk files ---
.DS_Store         # Mac
Thumbs.db         # Windows

# --- IDE config folders ---
.vscode/
.idea/

# --- Jupyter notebooks checkpoints ---
.ipynb_checkpoints/